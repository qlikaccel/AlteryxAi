# BigQuery/dbt publish settings for the Alteryx accelerator.
# Copy these into .env and fill values for your GCP environment.

GCP_PROJECT_ID=deft-ellipse-368004
GCP_BIGQUERY_DATASET=alteryx_poc
GCP_BIGQUERY_SOURCE_DATASET=alteryx_poc
GCP_BIGQUERY_LOCATION=US

# oauth uses Application Default Credentials on the backend host.
# service-account requires GOOGLE_APPLICATION_CREDENTIALS or GCP_SERVICE_ACCOUNT_JSON.
GCP_DBT_AUTH_METHOD=oauth
GOOGLE_APPLICATION_CREDENTIALS=
GCP_SERVICE_ACCOUNT_JSON=

DBT_EXECUTABLE=dbt
DBT_THREADS=4
DBT_COMMAND_TIMEOUT_SECONDS=600

# Dataform publish settings. Install @dataform/cli where the backend runs.
DATAFORM_EXECUTABLE=dataform
DATAFORM_COMMAND_TIMEOUT_SECONDS=600

# Persistent GCP Dataform repository publish settings.
# This writes generated workflow_settings.yaml / SQLX / JS files into a Dataform workspace.
GCP_DATAFORM_LOCATION=us-central1
GCP_DATAFORM_REPOSITORY=
GCP_DATAFORM_WORKSPACE=alteryx-generated
GCP_DATAFORM_COMMIT=false
GCP_DATAFORM_COMMIT_AUTHOR_NAME=Alteryx Accelerator
GCP_DATAFORM_COMMIT_AUTHOR_EMAIL=alteryx-accelerator@example.com
GCP_DATAFORM_COMMIT_MESSAGE=
